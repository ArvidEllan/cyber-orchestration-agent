# Cyber Orchestration Agent Environment Variables

# Required for AI remediation (Claude)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# AWS credentials (optional - uses standard credential chain by default)
# Prefer using AWS_PROFILE or instance roles instead of hardcoding keys
AWS_PROFILE=default
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional configuration
LOG_LEVEL=info                    # debug | info | warn | error
CACHE_DIR=.remediation-cache      # Directory for AI response cache
